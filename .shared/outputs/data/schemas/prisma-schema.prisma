// seeneyu — Prisma Schema
// Generated by: data-engineer role | M2 delivery
// Database: PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")  // Neon requires this for migrations
}

// ─── Clip ─────────────────────────────────────────────────────────────────────
// Curated Hollywood movie clip with coaching metadata

model Clip {
  id                    String       @id @default(cuid())
  youtubeVideoId        String       // YouTube video ID (not full URL)
  startSec              Int          // clip start time in seconds
  endSec                Int          // clip end time in seconds
  movieTitle            String
  year                  Int?
  characterName         String?
  actorName             String?
  sceneDescription      String       @db.Text
  skillCategory         String       // eye-contact | open-posture | active-listening | vocal-pacing | confident-disagreement
  difficulty            String       // beginner | intermediate | advanced
  difficultyScore       Int          // 4–12 (sum of 4 dimensions)
  signalClarity         Int          // 1–3
  noiseLevel            Int          // 1–3
  contextDependency     Int          // 1–3
  replicationDifficulty Int          // 1–3
  annotation            String       @db.Text    // main annotation shown during viewing
  contextNote           String?      @db.Text    // optional backstory
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  annotations   Annotation[]
  sessions      UserSession[]

  @@index([skillCategory])
  @@index([difficulty])
  @@index([skillCategory, difficulty])
}

// ─── Annotation ───────────────────────────────────────────────────────────────
// Timed annotations that appear as overlay cards during clip playback

model Annotation {
  id       String @id @default(cuid())
  clipId   String
  clip     Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  atSecond Int    // relative to clip start (0 = startSec of parent clip)
  note     String @db.Text
  type     String // eye_contact | posture | gesture | voice | expression

  @@index([clipId])
  @@index([clipId, atSecond])
}

// ─── UserSession ──────────────────────────────────────────────────────────────
// One session = one attempt at a clip (watch → record → feedback)

model UserSession {
  id           String    @id @default(cuid())
  clipId       String
  clip         Clip      @relation(fields: [clipId], references: [id])
  recordingUrl String?                // Vercel Blob URL (temp, TTL 24h)
  recordingKey String?                // Vercel Blob key for deletion
  status       String    @default("recording")  // recording | uploaded | feedback_pending | complete | failed
  feedback     Json?     // FeedbackResult object (see types below)
  scores       Json?     // { overallScore, dimensions: { label, score }[] }
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  @@index([clipId])
  @@index([status])
  @@index([createdAt])
}

// ─── Types (for reference — not Prisma models) ───────────────────────────────
//
// FeedbackResult (stored as JSON in UserSession.feedback):
// {
//   overallScore: number           // 0–100
//   summary: string                // one-sentence AI summary
