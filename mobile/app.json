{
  "expo": {
    "name": "seeneyu",
    "slug": "seeneyu",
    "scheme": "seeneyu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seeneyu.app",
      "infoPlist": {
        "NSCameraUsageDescription": "seeneyu uses the camera to record your body language practice sessions.",
        "NSMicrophoneUsageDescription": "seeneyu uses the microphone to capture audio during practice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fbbf24",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.seeneyu.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "seeneyu needs camera access for body language practice."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "seeneyu needs microphone access for audio recording."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "98a41dbd-6bc8-4a60-a5a5-ced1a2a27734"
      }
    },
    "owner": "haidongkixot"
  }
}
