{
  "manifest_version": 3,
  "name": "Seeneyu Mirror Mode",
  "short_name": "Seeneyu Mirror",
  "version": "0.1.0",
  "description": "Private real-time body-language coaching during Zoom / Meet / Teams. All processing happens on your device.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Open Seeneyu Mirror",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "permissions": ["sidePanel", "offscreen", "storage", "alarms"],
  "host_permissions": [
    "https://seeneyu.vercel.app/*",
    "https://seeneyu.com/*",
    "https://www.seeneyu.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src https://seeneyu.vercel.app https://seeneyu.com https://www.seeneyu.com"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html", "public/wasm/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  }
}
