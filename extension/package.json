{
  "name": "@seeneyu/extension",
  "version": "0.1.0",
  "private": true,
  "description": "Seeneyu Mirror Mode — Chrome / Edge extension (MV3)",
  "scripts": {
    "setup": "node scripts/download-models.mjs",
    "dev": "npm run setup && vite build --watch --mode development",
    "build": "npm run setup && vite build",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
