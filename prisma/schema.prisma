generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clip {
  id                    String   @id @default(cuid())
  youtubeVideoId        String
  startSec              Int
  endSec                Int
  movieTitle            String
  year                  Int?
  characterName         String?
  actorName             String?
  sceneDescription      String   @db.Text
  skillCategory         String
  difficulty            String
  difficultyScore       Int
  signalClarity         Int
  noiseLevel            Int
  contextDependency     Int
  replicationDifficulty Int
  annotation            String   @db.Text
  contextNote           String?  @db.Text
  script                String?  @db.Text
  screenplaySource      String?
  screenplayText        String?  @db.Text
  observationGuide      Json?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  annotations    Annotation[]
  sessions       UserSession[]
  practiceSteps  PracticeStep[]

  @@index([skillCategory])
  @@index([difficulty])
  @@index([skillCategory, difficulty])
}

model Annotation {
  id       String @id @default(cuid())
  clipId   String
  clip     Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  atSecond Int
  note     String @db.Text
  type     String

  @@index([clipId])
  @@index([clipId, atSecond])
}

model UserSession {
  id           String    @id @default(cuid())
  clipId       String
  clip         Clip      @relation(fields: [clipId], references: [id])
  recordingUrl String?
  recordingKey String?
  thumbnailUrl String?
  frameUrls    String?   @db.Text   // JSON array of image URLs for GPT-4o Vision
  status       String    @default("recording")
  feedback     Json?
  scores       Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])

  @@index([clipId])
  @@index([status])
  @@index([createdAt])
}

// ── Auth models (NextAuth.js v4 Prisma adapter) ────────────────────────────

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  name               String?
  image              String?
  role               String          @default("learner")
  status             String          @default("pending") // pending | approved | rejected | suspended
  statusNote         String?         @db.Text
  approvedAt         DateTime?
  approvedBy         String?
  passwordHash       String?
  emailVerified      DateTime?
  bio                String?         @db.Text
  avatarUrl          String?
  phone              String?
  location           String?
  onboardingComplete Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accounts           Account[]
  authSessions       AuthSession[]
  userSessions       UserSession[]
  skillBaselines     SkillBaseline[]
  foundationProgress FoundationProgress[]
  arcadeAttempts     ArcadeAttempt[]
  activityEvents     ActivityEvent[]
  plan               String          @default("basic")
  subscriptions      Subscription[]
  comments           Comment[]
  assistantConversations AssistantConversation[]
  gamification       UserGamification?

  @@index([status])
}

model SkillBaseline {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillCategory String
  level         String   // 'beginner' | 'intermediate' | 'advanced'
  selfRating    String   // original self-report ('beginner' | 'intermediate' | 'advanced')
  createdAt     DateTime @default(now())

  @@unique([userId, skillCategory])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PracticeStep {
  id                String @id @default(cuid())
  clipId            String
  clip              Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  stepNumber        Int
  skillFocus        String
  instruction       String @db.Text
  tip               String? @db.Text
  targetDurationSec Int     @default(20)

  @@index([clipId])
}

model MicroSession {
  id           String   @id @default(cuid())
  sessionId    String?
  clipId       String
  stepNumber   Int
  recordingUrl String?
  frameUrls    String?  @db.Text
  audioUrl     String?
  transcript   String?  @db.Text
  feedback     Json?
  status       String   @default("recording")
  createdAt    DateTime @default(now())

  @@index([clipId])
}

model FoundationCourse {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String
  description String             @db.Text
  icon        String
  color       String
  order       Int
  lessons     FoundationLesson[]
  createdAt   DateTime           @default(now())
}

model FoundationLesson {
  id         String               @id @default(cuid())
  courseId   String
  course     FoundationCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  theoryHtml String               @db.Text
  order      Int
  examples   LessonExample[]
  questions  QuizQuestion[]
  progress   FoundationProgress[]
  comments   Comment[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model LessonExample {
  id          String           @id @default(cuid())
  lessonId    String
  lesson      FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  youtubeId   String
  title       String
  description String           @db.Text
  startTime   Int?

  @@index([lessonId])
}

model QuizQuestion {
  id           String           @id @default(cuid())
  lessonId     String
  lesson       FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question     String
  options      Json
  correctIndex Int
  explanation  String           @db.Text
  order        Int              @default(0)

  @@index([lessonId])
}

model CrawlJob {
  id            String        @id @default(cuid())
  name          String
  skillCategory String
  technique     String?
  keywords      Json          // String[]
  difficulty    String?       // 'beginner' | 'intermediate' | 'advanced' | 'all'
  maxResults    Int           @default(20)
  status        String        @default("pending") // pending | running | complete | failed
  errorMessage  String?       @db.Text
  createdBy     String        // admin userId
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  results       CrawlResult[]

  @@index([status])
  @@index([createdBy])
}

model CrawlResult {
  id             String   @id @default(cuid())
  jobId          String
  job            CrawlJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  youtubeId      String
  title          String
  channelName    String
  thumbnailUrl   String
  description    String   @db.Text
  durationSec    Int?
  publishedAt    String?
  viewCount      Int?
  relevanceScore Float    @default(0)  // 0-10 from GPT-4o
  aiAnalysis     String?  @db.Text
  status         String   @default("pending") // pending | approved | rejected
  approvedClipId String?
  createdAt      DateTime @default(now())

  @@index([jobId])
  @@index([jobId, status])
}

model FoundationProgress {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quizScore   Int?
  quizPassed  Boolean          @default(false)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

// ── Arcade models ────────────────────────────────────────────────────

model ArcadeBundle {
  id          String             @id @default(cuid())
  title       String
  description String             @db.Text
  theme       String
  difficulty  String
  xpReward    Int                @default(100)
  challenges  ArcadeChallenge[]
  createdAt   DateTime           @default(now())
}

model ArcadeChallenge {
  id                String          @id @default(cuid())
  bundleId          String
  bundle            ArcadeBundle    @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  type              String          // facial | gesture
  title             String
  description       String          @db.Text
  context           String          @db.Text
  referenceImageUrl String?
  sourceClipId      String?
  sourceTimestamp    Int?
  difficulty        String
  xpReward          Int             @default(20)
  orderIndex        Int
  attempts          ArcadeAttempt[]
  comments          Comment[]

  @@index([bundleId])
}

model ArcadeAttempt {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId  String
  challenge    ArcadeChallenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  score        Int
  breakdown    Json
  feedbackLine String?          @db.Text
  recordingUrl String?
  createdAt    DateTime         @default(now())

  @@index([userId])
  @@index([challengeId])
  @@index([userId, challengeId])
}

// ── Activity & Analytics models ────────────────────────────────────────

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type])
}

model AnalysisMetric {
  id            String   @id @default(cuid())
  sessionType   String
  durationMs    Int
  faceDetected  Boolean
  poseDetected  Boolean
  snapshotCount Int
  score         Int?
  createdAt     DateTime @default(now())

  @@index([sessionType])
  @@index([createdAt])
}

// ── Subscription & Payment models ──────────────────────────────────────

model Plan {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  tagline       String?
  monthlyPrice  Float          @default(0)
  annualPrice   Float?
  features      Json
  videoLimitSec Int            @default(5)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId       String
  plan         Plan      @relation(fields: [planId], references: [id])
  status       String    @default("active")
  period       String    @default("monthly")
  startDate    DateTime  @default(now())
  endDate      DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  payments     Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  gateway        String
  gatewayOrderId String?
  amount         Float
  currency       String       @default("USD")
  status         String       @default("pending")
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
  @@index([gateway, gatewayOrderId])
}

// ── Discussion models ────────────────────────────────────────────────

model Comment {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String?
  lesson      FoundationLesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  challengeId String?
  challenge   ArcadeChallenge?  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Comment[]         @relation("CommentReplies")
  body        String            @db.Text
  isHidden    Boolean           @default(false)
  hiddenBy    String?
  hiddenAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([lessonId, createdAt])
  @@index([challengeId, createdAt])
  @@index([parentId])
  @@index([userId])
}

// ── AI Assistant models ──────────────────────────────────────────────

model AssistantConversation {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  context   String
  messages  AssistantMessage[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId])
  @@index([userId, context])
}

model AssistantMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String                @db.Text
  audioUrl       String?
  createdAt      DateTime              @default(now())

  @@index([conversationId, createdAt])
}

// ── Toolkit: Data Crawler models ──────────────────────────────────────

model ContentSource {
  id           String   @id @default(cuid())
  type         String   // 'article' | 'research_paper' | 'expression_db' | 'youtube_timestamp'
  url          String
  title        String
  rawContent   String?  @db.Text
  metadata     Json?
  status       String   @default("raw") // raw | curated | published | rejected
  curatedBy    String?
  curatedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

model ExpressionAsset {
  id           String   @id @default(cuid())
  imageUrl     String
  sourceUrl    String?
  label        String   // "surprise", "contempt", etc.
  description  String?  @db.Text
  tags         Json     // String[] of descriptive tags
  confidence   Float?
  userVotes    Int      @default(0)
  status       String   @default("pending") // pending | verified | rejected
  createdAt    DateTime @default(now())

  @@index([label])
  @@index([status])
}

// ── Gamification models ──────────────────────────────────────────────

model UserGamification {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp          Int      @default(0)
  level            Int      @default(1)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate String?
  streakFreezes    Int      @default(0)
  hearts           Int      @default(5)
  heartsRefillAt   DateTime?
  updatedAt        DateTime @updatedAt
  @@index([totalXp])
  @@index([currentStreak])
}

model XpTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  source    String
  sourceId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

model DailyQuest {
  id          String   @id @default(cuid())
  userId      String
  date        String
  questType   String
  description String
  target      Int      @default(1)
  progress    Int      @default(0)
  xpReward    Int      @default(50)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  @@unique([userId, date, questType])
  @@index([userId, date])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  iconEmoji   String      @default("\uD83C\uDFC6")
  category    String
  criteria    Json
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())
  @@unique([userId, badgeId])
  @@index([userId])
}

// ── Mini-Games models ──────────────────────────────────────────────────

model MiniGame {
  id          String       @id @default(cuid())
  type        String       @unique // 'guess_expression' | 'match_expression' | 'expression_king'
  title       String
  description String       @db.Text
  isActive    Boolean      @default(true)
  config      Json         // { timePerRound, totalRounds, passingScore }
  createdAt   DateTime     @default(now())
  rounds      MiniGameRound[]
  sessions    MiniGameSession[]
}

model MiniGameRound {
  id            String    @id @default(cuid())
  gameId        String
  game          MiniGame  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orderIndex    Int
  prompt        String    @db.Text
  imageUrl      String?
  correctAnswer String?
  options       Json?     // String[] for multiple choice
  @@index([gameId])
}

model MiniGameSession {
  id            String    @id @default(cuid())
  gameId        String
  game          MiniGame  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId      String?
  playerName    String?
  score         Int       @default(0)
  totalRounds   Int
  responses     Json      // Array of { roundId, answer, correct, timeMs }
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  @@index([gameId, score])
  @@index([playerId])
}

model ExpressionSubmission {
  id             String   @id @default(cuid())
  sessionId      String?
  challengeLabel String
  imageUrl       String
  aiScore        Int?
  aiAnalysis     String?  @db.Text
  status         String   @default("pending") // pending | approved | rejected
  createdAt      DateTime @default(now())
  @@index([challengeLabel])
  @@index([status])
}

// ── Error Logging ──────────────────────────────────────────────────

model ErrorLog {
  id          String   @id @default(cuid())
  level       String   // 'error' | 'warn' | 'info'
  source      String   // 'api' | 'client' | 'user-report' | 'cron'
  message     String   @db.Text
  stack       String?  @db.Text
  metadata    Json?
  userId      String?
  resolved    Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([resolved])
  @@index([createdAt])
}

// ── CMS models ──────────────────────────────────────────────────────

model CmsPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     Json
  status      String   @default("draft")
  publishedAt DateTime?
  createdBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  @@index([slug, status])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?  @db.Text
  body        String   @db.Text
  coverImage  String?
  tags        Json?
  status      String   @default("draft")
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([status, publishedAt])
}

model SiteSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  title       String
  bio         String?  @db.Text
  avatarUrl   String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([isActive, order])
}

// ── Game Data Pipeline models ──────────────────────────────────────────

model GameDataExport {
  id            String    @id @default(cuid())
  name          String
  format        String    // 'csv' | 'json'
  filters       Json
  recordCount   Int       @default(0)
  fileUrl       String?
  status        String    @default("pending")
  createdBy     String
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  @@index([status])
}

model TrainingDataLabel {
  id              String    @id @default(cuid())
  submissionId    String
  expressionLabel String
  confidence      Float
  validatedBy     String?
  validatedAt     DateTime?
  createdAt       DateTime  @default(now())
  @@index([expressionLabel])
  @@index([submissionId])
}

// ── Social & Competitive models ──────────────────────────────────────

model Leaderboard {
  id        String   @id @default(cuid())
  type      String
  period    String
  entries   Json
  updatedAt DateTime @updatedAt
  @@unique([type, period])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  endpoint     String   @db.Text
  keys         Json
  createdAt    DateTime @default(now())
  @@index([userId])
}
