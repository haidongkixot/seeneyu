generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clip {
  id                    String   @id @default(cuid())
  youtubeVideoId        String
  startSec              Int
  endSec                Int
  movieTitle            String
  year                  Int?
  characterName         String?
  actorName             String?
  sceneDescription      String   @db.Text
  skillCategory         String
  difficulty            String
  difficultyScore       Int
  signalClarity         Int
  noiseLevel            Int
  contextDependency     Int
  replicationDifficulty Int
  annotation            String   @db.Text
  contextNote           String?  @db.Text
  script                String?  @db.Text
  screenplaySource      String?
  screenplayText        String?  @db.Text
  observationGuide      Json?
  mediaType             String? // 'youtube' (default/null) | 'ai_image' | 'ai_video'
  mediaUrl              String? // direct URL for ai_image/ai_video
  aiContentRequestId    String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  annotations   Annotation[]
  sessions      UserSession[]
  practiceSteps PracticeStep[]
  tags          ClipTag[]

  @@index([skillCategory])
  @@index([difficulty])
  @@index([skillCategory, difficulty])
}

model Annotation {
  id       String @id @default(cuid())
  clipId   String
  clip     Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  atSecond Int
  note     String @db.Text
  type     String

  @@index([clipId])
  @@index([clipId, atSecond])
}

model UserSession {
  id                   String    @id @default(cuid())
  clipId               String
  clip                 Clip      @relation(fields: [clipId], references: [id])
  recordingUrl         String?
  recordingKey         String?
  thumbnailUrl         String?
  frameUrls            String?   @db.Text // JSON array of image URLs for GPT-4o Vision
  status               String    @default("recording")
  feedback             Json?
  scores               Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id])
  // ── I2: Feedforward ──
  snapshotScores       Json? // [{sec: number, score: number}] per-frame scores for peak detection
  recordingDurationSec Int? // needed for timestamp calculation
  // ── I3: Spaced Review ──
  nextReviewAt         DateTime?
  reviewCount          Int       @default(0)

  @@index([clipId])
  @@index([status])
  @@index([createdAt])
  @@index([nextReviewAt])
}

// ── Auth models (NextAuth.js v4 Prisma adapter) ────────────────────────────

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String?
  image                  String?
  role                   String                  @default("learner")
  status                 String                  @default("pending") // pending | approved | rejected | suspended
  statusNote             String?                 @db.Text
  approvedAt             DateTime?
  approvedBy             String?
  passwordHash           String?
  emailVerified          DateTime?
  bio                    String?                 @db.Text
  avatarUrl              String?
  phone                  String?
  location               String?
  onboardingComplete     Boolean                 @default(false)
  tourCompleted          Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  authSessions           AuthSession[]
  userSessions           UserSession[]
  skillBaselines         SkillBaseline[]
  foundationProgress     FoundationProgress[]
  arcadeAttempts         ArcadeAttempt[]
  activityEvents         ActivityEvent[]
  plan                   String                  @default("basic")
  subscriptions          Subscription[]
  comments               Comment[]
  assistantConversations AssistantConversation[]
  gamification           UserGamification?
  learnerProfile         LearnerProfile?
  coupons                CouponRedemption[]
  referralsGiven         Referral[]              @relation("ReferralsGiven")
  referralsReceived      Referral[]              @relation("ReferralsReceived")
  teamPlanId             String?
  teamPlan               TeamPlan?               @relation(fields: [teamPlanId], references: [id])
  managedTeams           TeamPlan[]              @relation("TeamAdmin")
  preferences            UserPreferences?

  @@index([status])
}

model SkillBaseline {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillCategory String
  level         String // 'beginner' | 'intermediate' | 'advanced'
  selfRating    String // original self-report ('beginner' | 'intermediate' | 'advanced')
  createdAt     DateTime @default(now())

  @@unique([userId, skillCategory])
  @@index([userId])
}

// ── LC: Clip Tags (genre, purpose, character traits) ──────────────────────────

model ClipTag {
  id         String   @id @default(cuid())
  clipId     String
  clip       Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  category   String // 'genre' | 'purpose' | 'trait'
  value      String // e.g. 'drama', 'for-work', 'confident'
  source     String   @default("manual") // 'manual' | 'ai-auto' | 'ai-confirmed'
  confidence Float?
  createdAt  DateTime @default(now())

  @@unique([clipId, category, value])
  @@index([category, value])
}

// ── LC: User Preferences (personalized learning curve) ────────────────────────

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal      String? // 'job-interview' | 'public-speaking' | 'dating-social' | 'leadership' | 'performing-career' | 'education'
  genres    Json     @default("[]") // String[] of genre slugs
  purposes  Json     @default("[]") // String[] of purpose slugs
  traits    Json     @default("[]") // String[] of trait slugs
  gender    String? // 'male' | 'female' | 'non-binary' | 'prefer-not-to-say'
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PracticeStep {
  id                String  @id @default(cuid())
  clipId            String
  clip              Clip    @relation(fields: [clipId], references: [id], onDelete: Cascade)
  stepNumber        Int
  skillFocus        String
  instruction       String  @db.Text
  tip               String? @db.Text
  targetDurationSec Int     @default(20)
  demoImageUrl      String? // AI-generated demo image for this step
  subSteps          Json? // [{order, text, imageUrl?}]
  voiceUrl          String? // ElevenLabs TTS audio URL (Vercel Blob)

  @@index([clipId])
}

// ── Practice Ideating (Admin Toolkit) ─────────────────────────────────────────
// Stores batches of AI-generated practice ideas produced from a PM prompt.
// Each batch contains 10-50 practice objects ready for a video-generation tool.

model PracticeIdeaBatch {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("draft") // draft | generating | complete | failed
  config    Json // { totalCount, skills, difficultyMix, stylePixarRatio, tone, language, characterTheme, pmPrompt }
  ideas     Json? // array of generated practice idea objects (same shape as ai-practices-batch-01.json)
  count     Int      @default(0)
  error     String?  @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
}

model MicroSession {
  id           String   @id @default(cuid())
  sessionId    String?
  clipId       String
  stepNumber   Int
  recordingUrl String?
  frameUrls    String?  @db.Text
  audioUrl     String?
  transcript   String?  @db.Text
  feedback     Json?
  status       String   @default("recording")
  createdAt    DateTime @default(now())

  @@index([clipId])
}

model FoundationCourse {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String
  description String             @db.Text
  icon        String
  color       String
  order       Int
  isVip       Boolean            @default(false)
  lessons     FoundationLesson[]
  createdAt   DateTime           @default(now())
}

model FoundationLesson {
  id         String               @id @default(cuid())
  courseId   String
  course     FoundationCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  theoryHtml String               @db.Text
  order      Int
  examples   LessonExample[]
  questions  QuizQuestion[]
  progress   FoundationProgress[]
  comments   Comment[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model LessonExample {
  id          String           @id @default(cuid())
  lessonId    String
  lesson      FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  youtubeId   String
  title       String
  description String           @db.Text
  startTime   Int?
  mediaUrl    String?
  mediaType   String?

  @@index([lessonId])
}

model QuizQuestion {
  id           String           @id @default(cuid())
  lessonId     String
  lesson       FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question     String
  options      Json
  correctIndex Int
  explanation  String           @db.Text
  order        Int              @default(0)

  @@index([lessonId])
}

model CrawlJob {
  id            String        @id @default(cuid())
  name          String
  skillCategory String
  technique     String?
  keywords      Json // String[]
  difficulty    String? // 'beginner' | 'intermediate' | 'advanced' | 'all'
  maxResults    Int           @default(20)
  status        String        @default("pending") // pending | running | complete | failed
  errorMessage  String?       @db.Text
  createdBy     String // admin userId
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  results       CrawlResult[]

  @@index([status])
  @@index([createdBy])
}

model CrawlResult {
  id             String   @id @default(cuid())
  jobId          String
  job            CrawlJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  youtubeId      String
  title          String
  channelName    String
  thumbnailUrl   String
  description    String   @db.Text
  durationSec    Int?
  publishedAt    String?
  viewCount      Int?
  relevanceScore Float    @default(0) // 0-10 from GPT-4o
  aiAnalysis     String?  @db.Text
  status         String   @default("pending") // pending | approved | rejected
  approvedClipId String?
  createdAt      DateTime @default(now())

  @@index([jobId])
  @@index([jobId, status])
}

model FoundationProgress {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quizScore   Int?
  quizPassed  Boolean          @default(false)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

// ── Arcade models ────────────────────────────────────────────────────

model ArcadeBundle {
  id          String            @id @default(cuid())
  title       String
  description String            @db.Text
  theme       String
  difficulty  String
  xpReward    Int               @default(100)
  challenges  ArcadeChallenge[]
  createdAt   DateTime          @default(now())
}

model ArcadeChallenge {
  id                String          @id @default(cuid())
  bundleId          String
  bundle            ArcadeBundle    @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  type              String // facial | gesture
  title             String
  description       String          @db.Text
  context           String          @db.Text
  referenceImageUrl String?
  mediaUrl          String?
  mediaType         String?
  sourceClipId      String?
  sourceTimestamp   Int?
  difficulty        String
  xpReward          Int             @default(20)
  orderIndex        Int
  guidanceSteps     Json? // [{stepNumber, instruction, tip?, imageUrl?, voiceUrl?}]
  attempts          ArcadeAttempt[]
  comments          Comment[]

  @@index([bundleId])
}

model ArcadeAttempt {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId  String
  challenge    ArcadeChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  score        Int
  breakdown    Json
  feedbackLine String?         @db.Text
  recordingUrl String?
  createdAt    DateTime        @default(now())

  @@index([userId])
  @@index([challengeId])
  @@index([userId, challengeId])
}

// ── Activity & Analytics models ────────────────────────────────────────

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type])
}

model AnalysisMetric {
  id            String   @id @default(cuid())
  sessionType   String
  durationMs    Int
  faceDetected  Boolean
  poseDetected  Boolean
  snapshotCount Int
  score         Int?
  createdAt     DateTime @default(now())

  @@index([sessionType])
  @@index([createdAt])
}

// ── Subscription & Payment models ──────────────────────────────────────

model Plan {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  tagline       String?
  monthlyPrice  Float          @default(0)
  annualPrice   Float?
  features      Json
  videoLimitSec Int            @default(5)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  status           String    @default("active")
  period           String    @default("monthly")
  startDate        DateTime  @default(now())
  endDate          DateTime?
  cancelledAt      DateTime?
  trialStartedAt   DateTime?
  trialEndsAt      DateTime?
  autoRenew        Boolean   @default(true)
  stripeCustomerId String?
  stripeSubId      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payments         Payment[]

  @@index([userId])
  @@index([status])
  @@index([stripeSubId])
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  gateway        String
  gatewayOrderId String?
  amount         Float
  currency       String       @default("USD")
  status         String       @default("pending")
  discount       Float        @default(0)
  couponId       String?
  invoiceUrl     String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
  @@index([gateway, gatewayOrderId])
}

// Pending payment intent — links gateway orderId to user/plan BEFORE callback
// so we never have to pattern-match orderId suffix against user IDs.
model PaymentIntent {
  id        String   @id @default(cuid())
  orderId   String   @unique
  userId    String
  planSlug  String
  period    String
  amount    Float
  currency  String
  gateway   String
  status    String   @default("pending") // pending | completed | failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([gateway, status])
}

// ── Discussion models ────────────────────────────────────────────────

model Comment {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String?
  lesson      FoundationLesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  challengeId String?
  challenge   ArcadeChallenge?  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Comment[]         @relation("CommentReplies")
  body        String            @db.Text
  isHidden    Boolean           @default(false)
  hiddenBy    String?
  hiddenAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([lessonId, createdAt])
  @@index([challengeId, createdAt])
  @@index([parentId])
  @@index([userId])
}

// ── AI Assistant models ──────────────────────────────────────────────

model AssistantConversation {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  context   String
  messages  AssistantMessage[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
  @@index([userId, context])
}

model AssistantMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String                @db.Text
  audioUrl       String?
  createdAt      DateTime              @default(now())

  @@index([conversationId, createdAt])
}

// ── Toolkit: Data Crawler models ──────────────────────────────────────

model ContentSource {
  id         String    @id @default(cuid())
  type       String // 'article' | 'research_paper' | 'expression_db' | 'youtube_timestamp'
  url        String
  title      String
  rawContent String?   @db.Text
  metadata   Json?
  status     String    @default("raw") // raw | curated | published | rejected
  curatedBy  String?
  curatedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

model ExpressionAsset {
  id          String   @id @default(cuid())
  imageUrl    String
  sourceUrl   String?
  label       String // "surprise", "contempt", etc.
  description String?  @db.Text
  tags        Json // String[] of descriptive tags
  confidence  Float?
  userVotes   Int      @default(0)
  status      String   @default("pending") // pending | verified | rejected
  createdAt   DateTime @default(now())

  @@index([label])
  @@index([status])
}

// ── Gamification models ──────────────────────────────────────────────

model UserGamification {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp          Int       @default(0)
  level            Int       @default(1)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate String?
  streakFreezes    Int       @default(0)
  hearts           Int       @default(5)
  heartsRefillAt   DateTime?
  updatedAt        DateTime  @updatedAt

  @@index([totalXp])
  @@index([currentStreak])
}

model XpTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  source    String
  sourceId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model DailyQuest {
  id          String   @id @default(cuid())
  userId      String
  date        String
  questType   String
  description String
  target      Int      @default(1)
  progress    Int      @default(0)
  xpReward    Int      @default(50)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, date, questType])
  @@index([userId, date])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  iconEmoji   String      @default("\uD83C\uDFC6")
  category    String
  criteria    Json
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

// ── Mini-Games models ──────────────────────────────────────────────────

model MiniGame {
  id          String            @id @default(cuid())
  type        String            @unique // 'guess_expression' | 'match_expression' | 'expression_king'
  title       String
  description String            @db.Text
  isActive    Boolean           @default(true)
  config      Json // { timePerRound, totalRounds, passingScore }
  createdAt   DateTime          @default(now())
  rounds      MiniGameRound[]
  sessions    MiniGameSession[]
}

model MiniGameRound {
  id            String   @id @default(cuid())
  gameId        String
  game          MiniGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orderIndex    Int
  prompt        String   @db.Text
  imageUrl      String?
  correctAnswer String?
  options       Json? // String[] for multiple choice

  @@index([gameId])
}

model MiniGameSession {
  id          String    @id @default(cuid())
  gameId      String
  game        MiniGame  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId    String?
  playerName  String?
  score       Int       @default(0)
  totalRounds Int
  responses   Json // Array of { roundId, answer, correct, timeMs }
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([gameId, score])
  @@index([playerId])
}

model ExpressionSubmission {
  id             String   @id @default(cuid())
  sessionId      String?
  challengeLabel String
  imageUrl       String
  aiScore        Int?
  aiAnalysis     String?  @db.Text
  status         String   @default("pending") // pending | approved | rejected
  createdAt      DateTime @default(now())

  @@index([challengeLabel])
  @@index([status])
}

// ── Error Logging ──────────────────────────────────────────────────

model ErrorLog {
  id         String    @id @default(cuid())
  level      String // 'error' | 'warn' | 'info'
  source     String // 'api' | 'client' | 'user-report' | 'cron'
  message    String    @db.Text
  stack      String?   @db.Text
  metadata   Json?
  userId     String?
  resolved   Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([level])
  @@index([source])
  @@index([resolved])
  @@index([createdAt])
}

// ── CMS models ──────────────────────────────────────────────────────

model CmsPage {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     Json
  status      String    @default("draft")
  publishedAt DateTime?
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@index([slug, status])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  body        String    @db.Text
  coverImage  String?
  tags        Json?
  status      String    @default("draft")
  authorId    String?
  category    String    @default("blog") // "blog" | "knowledge"
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category, status])
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String?  @db.Text
  avatarUrl String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive, order])
}

// ── Game Data Pipeline models ──────────────────────────────────────────

model GameDataExport {
  id          String    @id @default(cuid())
  name        String
  format      String // 'csv' | 'json'
  filters     Json
  recordCount Int       @default(0)
  fileUrl     String?
  status      String    @default("pending")
  createdBy   String
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([status])
}

model TrainingDataLabel {
  id              String    @id @default(cuid())
  submissionId    String
  expressionLabel String
  confidence      Float
  validatedBy     String?
  validatedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([expressionLabel])
  @@index([submissionId])
}

// ── Social & Competitive models ──────────────────────────────────────

model Leaderboard {
  id        String   @id @default(cuid())
  type      String
  period    String
  entries   Json
  updatedAt DateTime @updatedAt

  @@unique([type, period])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  keys      Json
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── AI Content Generator models ──────────────────────────────────────

model AiContentRequest {
  id                   String             @id @default(cuid())
  expressionType       String
  bodyLanguageType     String
  scenePrompt          String?            @db.Text
  generatedDescription Json?
  imagePrompt          String?            @db.Text
  videoPrompt          String?            @db.Text
  provider             String             @default("pollinations")
  model                String?
  status               String             @default("draft")
  createdBy            String
  publishedClipId      String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  assets               AiGeneratedAsset[]
  // Collection grouping — links multiple requests into one batch from Practice Ideating
  collectionId         String?
  sourcePracticeIdeaId String?
  collectionTitle      String? // cached title for UI without re-fetching batch

  @@index([status])
  @@index([expressionType])
  @@index([collectionId])
}

model AiGeneratedAsset {
  id           String           @id @default(cuid())
  requestId    String
  request      AiContentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type         String
  provider     String
  model        String?
  prompt       String           @db.Text
  blobUrl      String?
  width        Int?
  height       Int?
  durationMs   Int?
  metadata     Json?
  status       String           @default("generating")
  errorMessage String?          @db.Text
  createdAt    DateTime         @default(now())

  @@index([requestId])
  @@index([status])
}

// ── Learning Assistant Engine models ──────────────────────────────────

model LearnerProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone                 String    @default("UTC")
  preferredChannels        Json      @default("[]")
  optOutChannels           Json      @default("[]")
  optimalPracticeTime      String?
  practiceTimeConfidence   Float     @default(0)
  avgSessionsPerWeek       Float     @default(0)
  engagementScore          Float     @default(50)
  lastEngagementCalc       DateTime?
  weakSkills               Json      @default("[]")
  strongSkills             Json      @default("[]")
  skillGapUpdatedAt        DateTime?
  notificationFrequency    String    @default("normal")
  whatsappPhone            String?
  whatsappOptIn            Boolean   @default(false)
  // Data consent (opt-out model — default: agree to store)
  dataConsentStorageAgreed Boolean   @default(true)
  dataConsentUpdatedAt     DateTime?
  dataConsentVersion       Int       @default(1)
  // M46 Mirror Mode: explicit opt-in for extension aggregate metrics (default false)
  extensionMetricsOptIn    Boolean   @default(false)
  extensionMetricsOptInAt  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([engagementScore])
}

// ── M46 Mirror Mode: browser-extension models ──────────────────────────
// Local-only MediaPipe HUD during real Zoom/Meet/Teams calls. Raw frames
// never leave the device. Only opt-in aggregate metrics sync here.

model ExtensionToken {
  id               String    @id @default(cuid())
  userId           String
  tokenHash        String    @unique // SHA-256(accessToken)
  refreshHash      String    @unique // SHA-256(refreshToken)
  extensionId      String // chrome.runtime.id, pinned (T5)
  userAgent        String?
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime // access-token expiry (+15 min), MANDATORY
  refreshExpiresAt DateTime // refresh-token expiry (+30 days)
  revokedAt        DateTime?
  lastUsedAt       DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt])
}

model ExtensionSession {
  id                 String    @id @default(cuid())
  userId             String
  startedAt          DateTime
  endedAt            DateTime
  durationSeconds    Int
  avgEyeContactPct   Float?
  avgPostureScore    Float?
  avgVocalPaceWpm    Float?
  sampleCount        Int
  clientVersion      String
  // Phase B: time series + Coach Ney write-up
  timeSeries         Json? // [{ t, eyeContact, posture, pace }] downsampled to ~1/s
  nudgesShown        Json? // [{ at, pattern, headline }]
  coachHeadline      String?
  coachSummary       String?   @db.Text
  coachWhatWorked    Json? // string[]
  coachWhatToImprove Json? // string[]
  coachNextSteps     Json? // string[]
  coachGeneratedAt   DateTime?
  // Phase C: gamification linkage
  xpAwarded          Int       @default(0)
  createdAt          DateTime  @default(now())

  @@index([userId, startedAt])
  @@index([userId, createdAt])
}

// Short-lived (2 min) pairing code issued from the web UI and consumed once
// by the extension's /token/issue call. DB-backed so it survives Vercel
// serverless Lambda cold-splits. The code itself is the authenticator for
// /token/issue — session cookies don't flow from chrome-extension:// origins.
model ExtensionPairingCode {
  code      String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([userId])
}

model LearningPlan {
  id             String   @id @default(cuid())
  userId         String
  type           String
  date           String
  activities     Json
  status         String   @default("active")
  completedCount Int      @default(0)
  totalCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, type, date])
  @@index([userId, status])
}

model ScheduledNotification {
  id            String    @id @default(cuid())
  userId        String
  triggerType   String
  channel       String
  scheduledFor  DateTime
  payload       Json
  priority      String    @default("normal")
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  errorMessage  String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([userId, triggerType])
}

model NotificationLog {
  id             String    @id @default(cuid())
  userId         String
  notificationId String?
  triggerType    String
  channel        String
  title          String
  body           String    @db.Text
  deepLink       String?
  deliveryStatus String
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([triggerType])
}

model NotificationTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  triggerType String
  channel     String
  subject     String?
  title       String
  body        String   @db.Text
  variables   Json     @default("[]")
  locale      String   @default("en")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([triggerType, channel, locale])
}

// ── Coupon & Trial models ────────────────────────────────────────────

model Coupon {
  id          String             @id @default(cuid())
  code        String             @unique
  discountPct Int // 0-100
  maxUses     Int                @default(100)
  usedCount   Int                @default(0)
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  redemptions CouponRedemption[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
}

// ── Growth: Referral & Teams models ─────────────────────────────────

model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referredId  String?
  code        String    @unique
  status      String    @default("pending") // pending | converted
  createdAt   DateTime  @default(now())
  convertedAt DateTime?
  referrer    User      @relation("ReferralsGiven", fields: [referrerId], references: [id])
  referred    User?     @relation("ReferralsReceived", fields: [referredId], references: [id])

  @@index([referrerId])
  @@index([code])
}

model TeamPlan {
  id           String   @id @default(cuid())
  name         String
  adminId      String
  seats        Int      @default(5)
  pricePerSeat Float    @default(8.0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  admin        User     @relation("TeamAdmin", fields: [adminId], references: [id])
  members      User[]

  @@index([adminId])
}

// ── Content Agent models ────────────────────────────────────────────

model ContentAgentCycle {
  id               String              @id @default(cuid())
  type             String // 'daily' | 'weekly'
  status           String              @default("analyzing") // analyzing | suggestions_ready | approved | generating | completed | failed
  analysisData     Json? // full gap analysis snapshot
  suggestionsCount Int                 @default(0)
  approvedCount    Int                 @default(0)
  generatedCount   Int                 @default(0)
  costEstimate     Float?
  actualCost       Float?
  approvedBy       String?
  approvedAt       DateTime?
  rejectedBy       String?
  rejectedAt       DateTime?
  completedAt      DateTime?
  errorMessage     String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  suggestions      ContentSuggestion[]

  @@index([status])
  @@index([createdAt])
}

model ContentSuggestion {
  id                String               @id @default(cuid())
  cycleId           String
  cycle             ContentAgentCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  expressionType    String
  bodyLanguageType  String
  skillCategory     String
  difficulty        String // beginner | intermediate | advanced
  rationale         String               @db.Text
  gapType           String // skill_gap | difficulty_gap | engagement_gap | content_variety
  priority          Int                  @default(5) // 1 = highest
  suggestedProvider String?
  suggestedModel    String?
  mediaType         String // 'image' | 'video'
  classification    String               @default("for_later") // 'for_public' | 'for_later'
  publishTargets    Json? // ['library', 'foundation', 'arcade']
  status            String               @default("pending") // pending | approved | rejected | generating | completed | failed
  adminNote         String?              @db.Text
  contentRequestId  String? // links to AiContentRequest once generation starts
  estimatedCost     Float?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  generationJobs    AgentGenerationJob[]

  @@index([cycleId])
  @@index([status])
  @@index([skillCategory])
  @@index([gapType])
}

model ContentGapSnapshot {
  id                 String   @id @default(cuid())
  cycleId            String?
  skillCoverage      Json // { "eye-contact": { total, beginner, intermediate, advanced }, ... }
  difficultyCoverage Json // { "beginner": 45, "intermediate": 30, "advanced": 15 }
  practiceFrequency  Json // { "eye-contact": 340, "facial-expressions": 520, ... }
  engagementBySkill  Json? // avg engagement score per skill
  contentFreshness   Json // days since last content added per skill
  totalUsers         Int      @default(0)
  activeUsers        Int      @default(0) // active in last 30 days
  recommendations    Json? // AI-generated text summary
  createdAt          DateTime @default(now())

  @@index([createdAt])
}

model CloudStorageConfig {
  id        String   @id @default(cuid())
  provider  String   @unique // 'google_drive' | 'onedrive' | 'vercel_blob'
  isEnabled Boolean  @default(false)
  config    Json // { folderId, accessToken, refreshToken, basePath, etc. }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentGenerationJob {
  id               String            @id @default(cuid())
  suggestionId     String
  suggestion       ContentSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  contentRequestId String?
  provider         String
  model            String?
  status           String            @default("queued") // queued | generating | uploading | completed | failed
  providerTaskId   String? // external task ID for polling
  blobUrl          String?
  cloudStorageUrl  String?
  errorMessage     String?           @db.Text
  retryCount       Int               @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([suggestionId])
}
