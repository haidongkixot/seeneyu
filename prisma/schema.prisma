generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clip {
  id                    String   @id @default(cuid())
  youtubeVideoId        String
  startSec              Int
  endSec                Int
  movieTitle            String
  year                  Int?
  characterName         String?
  actorName             String?
  sceneDescription      String   @db.Text
  skillCategory         String
  difficulty            String
  difficultyScore       Int
  signalClarity         Int
  noiseLevel            Int
  contextDependency     Int
  replicationDifficulty Int
  annotation            String   @db.Text
  contextNote           String?  @db.Text
  script                String?  @db.Text
  screenplaySource      String?
  observationGuide      Json?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  annotations    Annotation[]
  sessions       UserSession[]
  practiceSteps  PracticeStep[]

  @@index([skillCategory])
  @@index([difficulty])
  @@index([skillCategory, difficulty])
}

model Annotation {
  id       String @id @default(cuid())
  clipId   String
  clip     Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  atSecond Int
  note     String @db.Text
  type     String

  @@index([clipId])
  @@index([clipId, atSecond])
}

model UserSession {
  id           String    @id @default(cuid())
  clipId       String
  clip         Clip      @relation(fields: [clipId], references: [id])
  recordingUrl String?
  recordingKey String?
  frameUrls    String?   @db.Text   // JSON array of image URLs for GPT-4o Vision
  status       String    @default("recording")
  feedback     Json?
  scores       Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])

  @@index([clipId])
  @@index([status])
  @@index([createdAt])
}

// ── Auth models (NextAuth.js v4 Prisma adapter) ────────────────────────────

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  name               String?
  image              String?
  role               String          @default("learner")
  passwordHash       String?
  emailVerified      DateTime?
  onboardingComplete Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accounts           Account[]
  authSessions       AuthSession[]
  userSessions       UserSession[]
  skillBaselines     SkillBaseline[]
  foundationProgress FoundationProgress[]
}

model SkillBaseline {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillCategory String
  level         String   // 'beginner' | 'intermediate' | 'advanced'
  selfRating    String   // original self-report ('beginner' | 'intermediate' | 'advanced')
  createdAt     DateTime @default(now())

  @@unique([userId, skillCategory])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PracticeStep {
  id                String @id @default(cuid())
  clipId            String
  clip              Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  stepNumber        Int
  skillFocus        String
  instruction       String @db.Text
  tip               String? @db.Text
  targetDurationSec Int     @default(20)

  @@index([clipId])
}

model MicroSession {
  id           String   @id @default(cuid())
  sessionId    String?
  clipId       String
  stepNumber   Int
  recordingUrl String?
  frameUrls    String?  @db.Text
  audioUrl     String?
  transcript   String?  @db.Text
  feedback     Json?
  status       String   @default("recording")
  createdAt    DateTime @default(now())

  @@index([clipId])
}

model FoundationCourse {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String
  description String             @db.Text
  icon        String
  color       String
  order       Int
  lessons     FoundationLesson[]
  createdAt   DateTime           @default(now())
}

model FoundationLesson {
  id         String               @id @default(cuid())
  courseId   String
  course     FoundationCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  theoryHtml String               @db.Text
  order      Int
  examples   LessonExample[]
  questions  QuizQuestion[]
  progress   FoundationProgress[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model LessonExample {
  id          String           @id @default(cuid())
  lessonId    String
  lesson      FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  youtubeId   String
  title       String
  description String           @db.Text
  startTime   Int?

  @@index([lessonId])
}

model QuizQuestion {
  id           String           @id @default(cuid())
  lessonId     String
  lesson       FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question     String
  options      Json
  correctIndex Int
  explanation  String           @db.Text
  order        Int              @default(0)

  @@index([lessonId])
}

model CrawlJob {
  id            String        @id @default(cuid())
  name          String
  skillCategory String
  technique     String?
  keywords      Json          // String[]
  difficulty    String?       // 'beginner' | 'intermediate' | 'advanced' | 'all'
  maxResults    Int           @default(20)
  status        String        @default("pending") // pending | running | complete | failed
  errorMessage  String?       @db.Text
  createdBy     String        // admin userId
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  results       CrawlResult[]

  @@index([status])
  @@index([createdBy])
}

model CrawlResult {
  id             String   @id @default(cuid())
  jobId          String
  job            CrawlJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  youtubeId      String
  title          String
  channelName    String
  thumbnailUrl   String
  description    String   @db.Text
  durationSec    Int?
  publishedAt    String?
  viewCount      Int?
  relevanceScore Float    @default(0)  // 0-10 from GPT-4o
  aiAnalysis     String?  @db.Text
  status         String   @default("pending") // pending | approved | rejected
  approvedClipId String?
  createdAt      DateTime @default(now())

  @@index([jobId])
  @@index([jobId, status])
}

model FoundationProgress {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      FoundationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quizScore   Int?
  quizPassed  Boolean          @default(false)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}
